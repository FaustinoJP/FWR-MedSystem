generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum AppointmentStatus {
  SCHEDULED
  CHECKED_IN
  IN_TRIAGE
  IN_CONSULTATION
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum EncounterStatus {
  OPEN
  CLOSED
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PARTIALLY_PAID
  PAID
  CANCELLED
  VOID
}

enum PaymentMethodType {
  CASH
  CARD
  POS
  BANK_TRANSFER
  INSURANCE
  RUP
  EXEMPT
  OTHER
}

enum PaymentStatus {
  PENDING
  REFERENCE_GENERATED
  AWAITING_PAYMENT
  PAID
  FAILED
  EXPIRED
  CANCELLED
}

model Role {
  id          String  @id @default(cuid())
  name        String  @unique
  description String?
  users       User[]
}

model User {
  id           String     @id @default(cuid())
  name         String
  email        String     @unique
  passwordHash String
  roleId       String
  status       UserStatus @default(ACTIVE)

  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])

  role         Role          @relation(fields: [roleId], references: [id])
  appointments Appointment[] @relation("DoctorAppointments")
}

model Department {
  id           String        @id @default(cuid())
  name         String        @unique
  appointments Appointment[]
  services     Service[]
  users        User[]
}

model Patient {
  id          String   @id @default(cuid())
  patientCode String   @unique
  firstName   String
  lastName    String
  gender      Gender
  dateOfBirth DateTime
  phone       String?
  bloodGroup  String?
  createdAt   DateTime @default(now())

  appointments Appointment[]
  invoices     Invoice[]
}

model Appointment {
  id              String            @id @default(cuid())
  patientId       String
  doctorId        String
  departmentId    String
  appointmentDate DateTime
  status          AppointmentStatus @default(SCHEDULED)
  reason          String?

  patient       Patient        @relation(fields: [patientId], references: [id])
  doctor        User           @relation("DoctorAppointments", fields: [doctorId], references: [id])
  department    Department     @relation(fields: [departmentId], references: [id])
  Invoice       Invoice?
  triage        Triage?
  encounter     Encounter?
  prescriptions Prescription[]
  examRequests  ExamRequest[]

  createdAt DateTime @default(now())
}

model Medication {
  id           String  @id @default(cuid())
  name         String
  genericName  String?
  form         String?
  strength     String?
  minimumStock Int     @default(0)
  status       Boolean @default(true)
}

model PaymentMethod {
  id       String            @id @default(cuid())
  name     String            @unique
  type     PaymentMethodType
  isActive Boolean           @default(true)
  payments Payment[]
}

model Service {
  id           String      @id @default(cuid())
  code         String      @unique
  name         String
  unitPrice    Float
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])
}

model Invoice {
  id             String        @id @default(cuid())
  patientId      String
  appointmentId  String?       @unique
  invoiceNumber  String        @unique
  description    String?
  totalAmount    Float         @default(0)
  discountAmount Float         @default(0)
  paidAmount     Float         @default(0)
  balance        Float         @default(0)
  status         InvoiceStatus @default(DRAFT)
  issuedAt       DateTime      @default(now())
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  patient     Patient       @relation(fields: [patientId], references: [id])
  appointment Appointment?  @relation(fields: [appointmentId], references: [id])
  items       InvoiceItem[]
  payments    Payment[]
}

model InvoiceItem {
  id          String @id @default(cuid())
  invoiceId   String
  serviceType String
  description String
  quantity    Int
  unitPrice   Float
  totalPrice  Float

  invoice Invoice @relation(fields: [invoiceId], references: [id])
}

model Payment {
  id                    String        @id @default(cuid())
  invoiceId             String
  paymentMethodId       String
  amount                Float
  status                PaymentStatus @default(PENDING)
  reference             String?
  transactionReference  String?
  externalTransactionId String?
  paidAt                DateTime?
  expiresAt             DateTime?
  metadata              Json?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  invoice       Invoice       @relation(fields: [invoiceId], references: [id])
  paymentMethod PaymentMethod @relation(fields: [paymentMethodId], references: [id])
}

model Triage {
  id               String   @id @default(cuid())
  appointmentId    String   @unique
  weight           Float?
  height           Float?
  temperature      Float?
  bloodPressure    String?
  heartRate        Int?
  respiratoryRate  Int?
  oxygenSaturation Int?
  notes            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  appointment Appointment @relation(fields: [appointmentId], references: [id])
}

model Encounter {
  id                      String          @id @default(cuid())
  appointmentId           String          @unique
  status                  EncounterStatus @default(OPEN)
  chiefComplaint          String?
  historyOfPresentIllness String?
  physicalExam            String?
  assessment              String?
  plan                    String?
  createdAt               DateTime        @default(now())
  updatedAt               DateTime        @updatedAt

  appointment Appointment @relation(fields: [appointmentId], references: [id])
}

model Prescription {
  id             String   @id @default(cuid())
  appointmentId  String
  medicationName String
  dosage         String
  frequency      String
  duration       String
  instructions   String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  appointment Appointment @relation(fields: [appointmentId], references: [id])
}

// ======================
// MÓDULO LABORATÓRIO - Versão Completa (Fase 2)
// ======================

enum ExamStatus {
  PENDING     @map("pending")
  IN_PROGRESS @map("in_progress")
  COMPLETED   @map("completed")
  VALIDATED   @map("validated")
  CANCELLED   @map("cancelled")
}

enum ExamPriority {
  LOW    @map("low")
  NORMAL @map("normal")
  URGENT @map("urgent")
}

model ExamType {
  id          String  @id @default(cuid())
  name        String
  code        String  @unique
  description String?
  price       Decimal @db.Decimal(10, 2)
  department  String?
  category    String?
  isActive    Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  examRequests ExamRequest[]

  @@map("exam_types")
}

model ExamRequest {
  id String @id @default(cuid())

  appointmentId String
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  examTypeId String
  examType   ExamType @relation(fields: [examTypeId], references: [id])

  status   ExamStatus   @default(PENDING)
  priority ExamPriority @default(NORMAL)

  requestedBy String // User ID (médico)
  requestedAt DateTime @default(now())

  result      Json? // Resultados detalhados
  notes       String?
  validatedBy String? // User ID do laboratorista
  validatedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([appointmentId])
  @@index([examTypeId])
  @@index([status])
  @@map("exam_requests")
}
